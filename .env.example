# Copy this file to .env and fill in the values.
# Never commit .env — it is listed in .gitignore.

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Audience ID from https://resend.com/audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get from https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional fallback — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (primary database) ───────────────────────────────────────────────
# Project settings → API. The service role key is server-only — never expose it.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (legacy dual-write backup) ─────────────────────────────────
# The spreadsheet ID from the URL: /spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# Full service account JSON as a single-line string (no newlines)
# Generate at https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ── Notifications ─────────────────────────────────────────────────────────────
# Email address that receives form submissions, waitlist signups, and chatbot data
OWNER_EMAIL=you@example.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret token for /api/admin/waitlist — use: openssl rand -hex 32
ADMIN_SECRET=replace_with_a_long_random_secret
